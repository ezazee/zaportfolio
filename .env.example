# ─────────────────────────────────────────────────────────────────────────────
# Zaportfolio — Environment Variables Template
# Salin file ini ke .env lalu isi nilainya
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=https://yourdomain.com

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=your_random_secret_min_32_chars

# ── OAuth — Google ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── OAuth — GitHub ────────────────────────────────────────────────────────────
GITHUB_ID=your_github_oauth_app_id
GITHUB_SECRET=your_github_oauth_app_secret

# ── Author Identity ────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTHOR_EMAIL=your@email.com
NEXT_PUBLIC_AUTHOR_NAME=Your Name
NEXT_PUBLIC_AVATAR_URL=https://your-avatar-url.com/photo.jpg
NEXT_PUBLIC_RESUME_URL=https://link-to-your-resume.pdf

# ── Social Media ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GITHUB_USERNAME=your_github_username
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/in/yourprofile
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/yourusername
NEXT_PUBLIC_SOCIAL_WHATSAPP=https://wa.me/628xxxxxxxxxx
NEXT_PUBLIC_WHATSAPP_NUMBER=628xxxxxxxxxx

# ── Email (Nodemailer) ─────────────────────────────────────────────────────────
NODEMAILER_EMAIL=your@gmail.com
NODEMAILER_PW=your_gmail_app_password

# ── Dashboard — GitHub ─────────────────────────────────────────────────────────
GITHUB_READ_USER_TOKEN_PERSONAL=your_github_personal_access_token

# ── Dashboard — WakaTime ───────────────────────────────────────────────────────
NEXT_PUBLIC_WAKATIME_USERNAME=your_wakatime_username
WAKATIME_API_KEY=your_wakatime_api_key

# ── Dashboard — Umami Analytics ────────────────────────────────────────────────
NEXT_PUBLIC_UMAMI_USERNAME=your_umami_username
NEXT_PUBLIC_UMAMI_DOMAIN=https://cloud.umami.is
NEXT_PUBLIC_UMAMI_SHARE_URL=https://cloud.umami.is/share/your_share_id
UMAMI_API_KEY=your_umami_api_key
UMAMI_WEBSITE_ID_SITE=your_umami_website_id

# ── Dashboard — Monkeytype ─────────────────────────────────────────────────────
NEXT_PUBLIC_MONKEYTYPE_USERNAME=your_monkeytype_username
MONKEYTYPE_API_KEY=your_monkeytype_api_key

# ── Dashboard — Codewars ───────────────────────────────────────────────────────
NEXT_PUBLIC_CODEWARS_USERNAME=your_codewars_username
CODEWARS_USER_ID=your_codewars_user_id

# ── AI — Google Gemini (Smart Talk) ───────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key
